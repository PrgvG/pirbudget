# Database
# Для dev окружения (docker-compose.dev.yml) используйте порт 27018
# Для prod окружения (docker-compose.yml) используйте порт 27017
DATABASE_URL="mongodb://admin:password@localhost:27018/pirbudget?authSource=admin"

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN=7d

# Rate limit (опционально)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=10

